# Supagloo local-dev env scheme (Docker Compose stack).
#
# These are the DEV defaults matching docker-compose.yml. The root smoke-test
# harness reads them with these exact fallbacks, so copying this file is
# optional for local `docker compose up`. Later tasks (api/dbos, tasks 8/13/15)
# consume the same vars inside the containers.
#
#   cp .env.example .env.local   # optional; overrides the built-in fallbacks

# --- Postgres (single postgres:17 container, two logical databases) ---
POSTGRES_USER=supagloo
POSTGRES_PASSWORD=supagloo
# App schema (Prisma-managed) and DBOS system db. From the HOST use localhost;
# from inside the Compose network use host `postgres`.
DATABASE_URL=postgres://supagloo:supagloo@localhost:5432/supagloo
DBOS_DATABASE_URL=postgres://supagloo:supagloo@localhost:5432/supagloo_dbos

# --- Application secrets key (Task #12, design-delta §2.10) ---
# The single AES-256-GCM key the api/dbos containers use to encrypt/decrypt
# per-user provider secrets at rest (the OpenRouter API key, the Gloo client
# secret) — NOT itself per-user data; one key per deployment, shared by both
# services (a mismatch between them means decryption fails with AUTH_FAILED).
# 64-char hex (32 bytes). The value below is the same well-known dev-only
# placeholder used in supagloo-database-lib/.env.example — never use it in prod.
SECRETS_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# --- GitHub App (Task #11/#17, design-delta §2.3/§7) ---
# Required (fail-fast at boot) for BOTH the api and dbos containers — unlike the
# vars above, these have NO safe dev-only default (they're tied to a real
# registered GitHub App), so copying this file to a root .env is NOT optional
# once you need `docker compose up` to actually boot api/dbos.
#
# One pair per app registration, shared by api + dbos. api signs ~10-min App
# JWTs (GITHUB_APP_ID issuer + GITHUB_APP_PRIVATE_KEY) to verify installations
# and mint installation tokens, and builds the hosted install-picker URL
# (.../apps/{GITHUB_APP_SLUG}/installations/new); dbos's git-ops workflows sign
# their own App JWTs the same way to mint installation tokens directly (no HTTP
# hop through the api). The private key is the app's PKCS#1/PKCS#8 PEM as a
# SINGLE LINE with escaped \n (normalized to real newlines before signing) —
# e.g. `-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n`.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=

# Task #26 create-new-repo JIT hop (design-delta §2.3/§6b) — api-only (dbos has
# no user context). The App's OAuth-style user-to-server client id/secret: it
# exchanges a short-lived user authorization code for a per-request user access
# token, used once to create a repo under the user's account, then discarded.
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# --- S3 / MinIO (dual endpoint scheme — the presigned-URL gotcha) ---
# S3_ENDPOINT        : internal Docker-network address; server-side/container ops.
# S3_PUBLIC_ENDPOINT : host-reachable address; used to SIGN presigned URLs that a
#                      host-side browser/client must be able to reach.
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_BUCKET=supagloo-dev
S3_ACCESS_KEY=supagloo
S3_SECRET_KEY=supagloo-dev
S3_REGION=us-east-1

# --- Provider-stub harness (Task #9 — docker-compose.test.yml overlay) ---
# Dual-endpoint scheme, same reasoning as S3:
#   * The API container reaches each stub at its INTERNAL Compose-network name
#     (set on the api service by the overlay), e.g. http://github-stub:8080.
#   * The host-run e2e self-test reaches each stub at its PUBLISHED host port
#     below (these are what tests/support/dev-config.ts PROVIDERS reads).
# The stub servers are TEST-ONLY and never ship in a production image.
GITHUB_STUB_URL=http://localhost:4801
OPENROUTER_STUB_URL=http://localhost:4802
GLOO_STUB_URL=http://localhost:4803
YOUVERSION_STUB_URL=http://localhost:4804
GIT_SERVER_STUB_URL=http://localhost:4805

# --- E2E provider secrets (design-delta §10.8, task 34-E2) ---
# The real-provider gating e2e suites (api/dbos, tasks 34-E3/34-E4/34-E8) hit the
# LIVE OpenRouter / Gloo / YouVersion APIs. The three vars below are REQUIRED: a
# missing one must FAIL the e2e global-setup fast with an actionable message — a
# gating suite that silently skips its provider tests is a green lie. Only
# YOUVERSION_E2E_ACCESS_TOKEN (further down) is deliberately optional. CI wiring is
# out of scope (design-delta §9-Q12); this is the local-dev `.env` story only.

# YouVersion Platform API key (already wired — dbos sends it as a header).
YOUVERSION_APP_KEY=

# Real, live-verifiable Gloo AI client credentials. api-e2e drives the real connect
# routes with these; dbos-e2e live-mints a Gloo token before writing an encrypted row.
GLOO_CLIENT_ID=
GLOO_CLIENT_SECRET=

# A DEDICATED, LOW-BALANCE OpenRouter key (design-delta §10.3/§10.9) — the low cap is
# the backstop against a runaway suite. Never reuse a production key here.
OPENROUTER_E2E_TEST_API_KEY=

# Optional (the ONE deliberately-optional real spec, design-delta §10.4b): a dedicated
# test account's YouVersion access token for the live userinfo round-trip (34-E6).
# When unset, that spec skips LOUDLY (never silently). All the vars above do NOT skip.
YOUVERSION_E2E_ACCESS_TOKEN=